# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_USER=proxbet_user
DB_PASS=your_secure_password
DB_NAME=proxbet_db
DB_POOL_MAX_CONNECTIONS=10

# API Configuration
API_URL=https://example.com/api/matches
API_URL_LIVE=https://example.com/api/live

# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHANNEL_ID=-1001234567890
TELEGRAM_ADMIN_IDS=123456789,987654321
TELEGRAM_POLL_TIMEOUT=25
TELEGRAM_BOT_STATE_PATH=./data/telegram_state.json
TELEGRAM_REQUIRED_CHANNEL_URL=https://t.me/your_channel
TELEGRAM_CUSTOM_EMOJI_WIN_IDS=
TELEGRAM_CUSTOM_EMOJI_LOSE_IDS=
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_CREDITS_TOPUP_URL=
TELEGRAM_AI_BUTTON_TEXT=🤖 AI-анализ

# Admin API Configuration
ADMIN_API_TOKEN=your_admin_api_token_here
ADMIN_PASSWORD=your_admin_password_here

# Health Endpoint Security (optional - for enhanced health endpoint)
HEALTH_AUTH_ENABLED=true
HEALTH_AUTH_USERNAME=health_user
HEALTH_AUTH_PASSWORD=your_health_password
HEALTH_ALLOWED_IPS=127.0.0.1,::1

# Metrics Endpoint Security
METRICS_AUTH_ENABLED=true
METRICS_SECRET_TOKEN=your_metrics_secret_token

# Alert Webhook Security
ALERT_WEBHOOK_SECRET=your_alert_webhook_secret

# Security Configuration
ENCRYPTION_KEY=your_32_byte_encryption_key_here_base64_encoded
RATE_LIMIT_REQUESTS=20
RATE_LIMIT_WINDOW=60

# Redis Configuration (optional)
# Default production path keeps Redis disabled unless you explicitly enable the `cache` profile.
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_KEY_PREFIX=proxbet:
REDIS_DEFAULT_TTL=86400

# Retry Configuration
RETRY_MAX_ATTEMPTS=3
RETRY_BASE_DELAY_MS=1000
RETRY_MAX_DELAY_MS=30000
RETRY_JITTER_FACTOR=0.1

# Backup Configuration
BACKUP_RETENTION_DAYS=7

# Debug Configuration
DEBUG_BANS=0
DEBUG_BANS_LIMIT=3

# Algorithm Configuration
ALGORITHM_VERSION=2
ALGORITHM1_DUAL_RUN=0
ALGORITHM1_V2_MIN_PROBABILITY=0.60
ALGORITHM1_V2_THRESHOLD_CANDIDATES=0.55,0.52,0.50
ALGORITHM1_V2_TIME_PRESSURE_EXPONENT=1.15
ALGORITHM1_V2_TIME_PRESSURE_EARLY_WINDOW_END=20
ALGORITHM1_V2_TIME_PRESSURE_EARLY_FLOOR=0.32

# AlgorithmX Configuration
ALGORITHMX_ENABLED=true
ALGORITHMX_SIGMOID_K=2.5
ALGORITHMX_SIGMOID_THRESHOLD=1.8
ALGORITHMX_DECISION_THRESHOLD_HIGH=0.60
ALGORITHMX_DECISION_THRESHOLD_LOW=0.20
ALGORITHMX_MIN_MINUTE=5
ALGORITHMX_MAX_MINUTE=45

# Logging
LOG_LEVEL=info
SCANNER_MATCH_BATCH_SIZE=100

# HTTP Client Configuration
HTTP_TIMEOUT=30
HTTP_RETRIES=3

# Statistics Service Configuration
STAT_API_BASE_URL=https://eventsstat.com
STAT_REQUEST_TIMEOUT_MS=10000
STAT_RETRY_COUNT=3
STAT_SLEEP_MS=1000
STAT_BATCH_LIMIT=100
STAT_STALE_AFTER_SECONDS=86400
STAT_VERSION=1
MATCH_UPSERT_BATCH_SIZE=100

# AI Configuration
AI_ANALYSIS_COST=1
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-pro

# Application Configuration
APP_URL=http://localhost:8080
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Worker Configuration
WORKER_NO_BOT=0
BACK_START_ARGS=
BACK_START_MINUTE_PIPELINE_INTERVAL_SEC=60
BACK_START_MINUTE_PIPELINE_INITIAL_DELAY_SEC=0
BACK_START_PARSERSTAT_INTERVAL_SEC=300
BACK_START_PARSERSTAT_INITIAL_DELAY_SEC=30
SCANNER_STATE_PATH=./data/scanner_state.json
