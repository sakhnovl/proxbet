# Public application URL
APP_URL=http://localhost:8080
APP_PORT=8080
ALLOWED_ORIGINS=

# Database credentials
DB_HOST=db
DB_PORT=3306
DB_USER=proxbet
DB_PASS=change_me_db_password
DB_NAME=proxbet
DB_ROOT_PASSWORD=change_me_root_password

# Docker database bootstrap values
DOCKER_DB_NAME=proxbet
DOCKER_DB_USER=proxbet
DOCKER_DB_PASS=change_me_db_password
DOCKER_DB_ROOT_PASSWORD=change_me_root_password
DOCKER_DB_FORWARD_PORT=3307
PHPMYADMIN_PORT=8081

# Telegram API
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_ADMIN_IDS=123456789,987654321
TELEGRAM_CHANNEL_ID=-1001234567890
TELEGRAM_REQUIRED_CHANNEL_URL=https://t.me/your_channel
TELEGRAM_BOT_STATE_PATH=/data/telegram_state.json
SCANNER_STATE_PATH=/data/scanner_state.json
TELEGRAM_CUSTOM_EMOJI_WIN_IDS=5206607081334906820
TELEGRAM_CUSTOM_EMOJI_LOSE_IDS=5210952531676504517
TELEGRAM_API_ID=your_api_id
TELEGRAM_API_HASH=your_api_hash
TELEGRAM_POLL_TIMEOUT=25

# Telegram AI Analysis
TELEGRAM_CREDITS_TOPUP_URL=https://t.me/your_payment_bot
TELEGRAM_AI_BUTTON_TEXT=🤖 Анализ Gemini
AI_ANALYSIS_COST=1
AI_TRIAL_BALANCE=5
AI_CACHE_TTL=3600
AI_RATE_LIMIT_PER_USER=10
AI_RATE_LIMIT_WINDOW=3600

# Gemini API (deprecated - use database management instead)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash
GEMINI_TIMEOUT=25
GEMINI_TEMPERATURE=0.4
GEMINI_MAX_OUTPUT_TOKENS=500

# Source data URLs
API_URL=https://example.com/service-api/LineFeed/Get1x2_VZip?sports=1&count=100&mode=4&country=1&getEmpty=true&minOffset=60
API_URL_LIVE=https://example.com/service-api/LiveFeed/Get1x2_VZip?sports=1&count=1000&mode=4&country=1&getEmpty=true

# Admin Panel
ADMIN_PASSWORD=change_me_to_a_strong_secret_password

# Statistics API (optional)
STAT_API_BASE_URL=https://eventsstat.com
STAT_REQUEST_TIMEOUT_MS=10000
STAT_RETRY_COUNT=3
STAT_SLEEP_MS=250
STAT_BATCH_LIMIT=100

# HTTP Client (optional)
HTTP_TIMEOUT=20
HTTP_RETRIES=3

# Debug (optional)
DEBUG_BANS=0
DEBUG_BANS_LIMIT=3

# Worker runtime options (optional)
WORKER_NO_BOT=0
BACK_START_ARGS=
